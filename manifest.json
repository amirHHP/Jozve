{
  "manifest_version": 3,
  "name": "DropIt",
  "version": "1.0.0",
  "description": "Offline-first drop-based knowledge capture extension",

  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "public/favicon.svg",
      "32": "public/favicon.svg",
      "48": "public/favicon.svg",
      "128": "public/favicon.svg"
    }
  },

  "icons": {
    "16": "public/favicon.svg",
    "32": "public/favicon.svg",
    "48": "public/favicon.svg",
    "128": "public/favicon.svg"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}