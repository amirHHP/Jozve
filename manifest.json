{
  "manifest_version": 3,
  "name": "DropIt",
  "version": "2.0.0",
  "description": "Offline-first drop-based knowledge capture extension",

  "permissions": [
    "storage",
    "contextMenus",
    "activeTab",
    "notifications",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_icon": {
      "16": "public/icon-16.png",
      "32": "public/icon-32.png",
      "48": "public/icon-48.png",
      "128": "public/icon-128.png"
    }
  },

  "side_panel": {
    "default_path": "index.html"
  },

  "icons": {
    "16": "public/icon-16.png",
    "32": "public/icon-32.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}